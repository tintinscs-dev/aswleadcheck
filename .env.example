# Postgres connection string (Supabase: Project Settings > Database > Connection string)
# - Chay local / prisma db push: dung chuoi "direct connection" (port 5432)
# - Deploy Vercel: dung chuoi "connection pooling" (port 6543) + them ?pgbouncer=true
DATABASE_URL="postgresql://postgres.xxxx:password@xxxx.pooler.supabase.com:5432/postgres"
# Chuoi bi mat cho NextAuth - tao bang: openssl rand -base64 32
NEXTAUTH_SECRET="thay-bang-chuoi-ngau-nhien-dai"
# URL cua app khi deploy (de trong khi chay local la http://localhost:3000)
NEXTAUTH_URL="http://localhost:3000"
